# Copy to .env and fill in. NEVER commit the real .env.

# Long random string. Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Dev default is SQLite. For prod on the VPS use Postgres, e.g.:
# DATABASE_URL=postgresql+psycopg://hound:password@localhost:5432/hound
DATABASE_URL=sqlite:///./hound.db

# Access token lifetime (minutes). Mobile devices use long-lived tokens.
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Where uploaded audio clips are stored on disk.
MEDIA_DIR=./media

# Comma-separated origins allowed to call the API from a browser (the dashboard).
# In prod set this to your dashboard's real https origin.
CORS_ORIGINS=*

# Bootstrap admin account, created on first startup if it does not exist.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
