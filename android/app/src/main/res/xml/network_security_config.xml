<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
      Production traffic must be HTTPS (default). These cleartext exceptions exist
      ONLY so you can test against a local dev server over http://.
      Add your PC's LAN IP here (e.g. 192.168.1.20) to test from a real phone.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>     <!-- emulator -> host -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <!-- <domain includeSubdomains="false">192.168.1.20</domain> --> <!-- your LAN IP -->
    </domain-config>
</network-security-config>
