<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Set up protection"
            android:textColor="@color/text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="24dp"
            android:text="Hound needs a few permissions to send your location and audio during an emergency, even when your screen is locked."
            android:textColor="@color/muted"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="18dp">

            <TextView
                android:id="@+id/checkPermissions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○ Location &amp; microphone"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnPermissions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:text="Grant"
                android:backgroundTint="@color/panel2"
                android:textColor="@color/text" />

            <TextView
                android:id="@+id/checkBackground"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○ Background location"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnBackground"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="16dp"
                android:text="Allow all the time"
                android:backgroundTint="@color/panel2"
                android:textColor="@color/text" />

            <TextView
                android:id="@+id/checkBattery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="○ Keep running in background"
                android:textColor="@color/text"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btnBattery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Disable battery limits"
                android:backgroundTint="@color/panel2"
                android:textColor="@color/text" />
        </LinearLayout>

        <Button
            android:id="@+id/btnFinish"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Activate Hound"
            android:backgroundTint="@color/accent"
            android:textColor="@color/white" />
    </LinearLayout>
</ScrollView>
